{
        "semi": true,
        "singleQuote": true,
        "tabWidth": 8,
        "trailingComma": "all",
        "bracketSpacing": true,
        "arrowParens": "always",
        "endOfLine": "lf",
        "printWidth": 80,
        "proseWrap": "always",
        "htmlWhitespaceSensitivity": "strict"
}
